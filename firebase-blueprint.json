{
  "entities": {
    "onboarding": {
      "title": "Onboarding Lead",
      "description": "Premium onboarding lead submission details with business and contact info.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the lead" },
        "companyName": { "type": "string", "description": "Name of the business or brand" },
        "industry": { "type": "string", "description": "Industry sector" },
        "companySize": { "type": "string", "description": "Number of employees" },
        "digitalMaturity": { "type": "string", "description": "Digital maturity level" },
        "bottleneck": { "type": "string", "description": "Primary digital business bottleneck" },
        "selectedModules": { "type": "array", "description": "List of selected tech modules" },
        "contactName": { "type": "string", "description": "Name of the contact person" },
        "contactEmail": { "type": "string", "description": "Email address of the contact" },
        "contactPhone": { "type": "string", "description": "Phone or WhatsApp number" },
        "customMessage": { "type": "string", "description": "Additional user comments" },
        "configuratorTotal": { "type": "number", "description": "Total estimated budget in USD" },
        "configuratorDuration": { "type": "number", "description": "Estimated production duration in weeks" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the lead was submitted" },
        "userId": { "type": "string", "description": "ID of the authenticated user who submitted" },
        "status": { "type": "string", "enum": ["pending", "processing", "contacted", "completed"], "description": "Processing state of the lead" }
      },
      "required": ["companyName", "contactName", "contactEmail", "contactPhone", "createdAt", "status"]
    },
    "userForm": {
      "title": "Connected Google Form",
      "description": "User connected Google Form configuration for dashboard tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique record identifier" },
        "userId": { "type": "string", "description": "The authenticated owner UID" },
        "formId": { "type": "string", "description": "Google Form identifier" },
        "formTitle": { "type": "string", "description": "Title of the Google Form" },
        "connectedAt": { "type": "string", "format": "date-time", "description": "Timestamp when connected" },
        "syncEnabled": { "type": "boolean", "description": "Whether sync is currently active" }
      },
      "required": ["userId", "formId", "formTitle", "connectedAt", "syncEnabled"]
    }
  },
  "firestore": {
    "/onboarding/{leadId}": {
      "schema": { "$ref": "#/entities/onboarding" },
      "description": "Individual onboarding lead registrations."
    },
    "/userForms/{formConfigId}": {
      "schema": { "$ref": "#/entities/userForm" },
      "description": "Connected Google Form tracking configs per authenticated user."
    }
  }
}
